# =============================================================================
# Focus Flight Ops - Variables de entorno para Docker Compose
# =============================================================================

# Base de datos
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_NAME=focus_flight_ops
DB_PORT=5432

# Backend (solo para perfil 'full')
JWT_SECRET=generate-a-random-256-bit-key-here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
