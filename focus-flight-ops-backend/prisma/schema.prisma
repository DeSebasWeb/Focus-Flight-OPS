generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTHENTICATION & USERS
// ============================================================

model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  firstName      String   @map("first_name") @db.VarChar(100)
  lastName       String   @map("last_name") @db.VarChar(100)
  phone          String   @db.VarChar(20)
  documentType   String   @map("document_type") @db.VarChar(10) // CC, CE, PASSPORT
  documentNumber String   @unique @map("document_number") @db.VarChar(30)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  pilot         Pilot?
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// PILOT CERTIFICATION (separated from User for 3NF)
// ============================================================

model Pilot {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  uaeacPilotNumber      String?  @unique @map("uaeac_pilot_number") @db.VarChar(50)
  licenseType           String   @map("license_type") @db.VarChar(20) // OPEN, SPECIFIC, CERTIFIED
  emergencyContactName  String?  @map("emergency_contact_name") @db.VarChar(100)
  emergencyContactPhone String?  @map("emergency_contact_phone") @db.VarChar(20)
  regulatoryVersion     String   @default("RAC100") @map("regulatory_version") @db.VarChar(20)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificates        Certificate[]
  insurancePolicies   InsurancePolicy[]
  drones              Drone[]
  missions            Mission[]
  flightLogs          FlightLog[]
  checklistExecutions ChecklistExecution[]
  emergencyEvents     EmergencyEvent[]

  @@map("pilots")
}

// ============================================================
// CERTIFICATES & INSURANCE
// ============================================================

model Certificate {
  id                String   @id @default(uuid()) @db.Uuid
  pilotId           String   @map("pilot_id") @db.Uuid
  type              String   @db.VarChar(20) // COMPETENCY, MEDICAL, TRAINING
  certificateNumber String   @map("certificate_number") @db.VarChar(50)
  issuingAuthority  String   @map("issuing_authority") @db.VarChar(100)
  issueDate         DateTime @map("issue_date") @db.Date
  expiryDate        DateTime @map("expiry_date") @db.Date
  documentUrl       String?  @map("document_url") @db.VarChar(500)
  isValid           Boolean  @default(true) @map("is_valid")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  pilot Pilot @relation(fields: [pilotId], references: [id], onDelete: Cascade)

  @@index([pilotId])
  @@map("certificates")
}

model InsurancePolicy {
  id              String   @id @default(uuid()) @db.Uuid
  pilotId         String   @map("pilot_id") @db.Uuid
  insurerName     String   @map("insurer_name") @db.VarChar(100)
  policyNumber    String   @map("policy_number") @db.VarChar(50)
  coverageType    String   @default("RC_EXTRACONTRACTUAL") @map("coverage_type") @db.VarChar(30)
  coverageAmountCop Decimal @map("coverage_amount_cop") @db.Decimal(15, 2)
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime @map("end_date") @db.Date
  documentUrl     String?  @map("document_url") @db.VarChar(500)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  pilot Pilot @relation(fields: [pilotId], references: [id], onDelete: Cascade)

  @@index([pilotId])
  @@map("insurance_policies")
}

// ============================================================
// FLEET / DRONES (3NF: manufacturer and model separated)
// ============================================================

model DroneManufacturer {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique @db.VarChar(100)

  models DroneModel[]

  @@map("drone_manufacturers")
}

model DroneModel {
  id               String  @id @default(uuid()) @db.Uuid
  manufacturerId   String  @map("manufacturer_id") @db.Uuid
  name             String  @db.VarChar(100)
  defaultMtowGrams Int?    @map("default_mtow_grams")
  defaultNumRotors Int?    @map("default_num_rotors")
  category         String? @db.VarChar(20) // OPEN, SPECIFIC, CERTIFIED

  manufacturer DroneManufacturer @relation(fields: [manufacturerId], references: [id])
  drones       Drone[]

  @@unique([manufacturerId, name])
  @@map("drone_models")
}

model Drone {
  id                 String   @id @default(uuid()) @db.Uuid
  pilotId            String   @map("pilot_id") @db.Uuid
  modelId            String   @map("model_id") @db.Uuid
  serialNumber       String   @unique @map("serial_number") @db.VarChar(50)
  registrationNumber String?  @unique @map("registration_number") @db.VarChar(20)
  mtowGrams          Int      @map("mtow_grams")
  firmwareVersion    String?  @map("firmware_version") @db.VarChar(50)
  purchaseDate       DateTime? @map("purchase_date") @db.Date
  photoUrl           String?  @map("photo_url") @db.VarChar(500)
  isActive           Boolean  @default(true) @map("is_active")
  totalFlightMinutes Decimal  @default(0) @map("total_flight_minutes") @db.Decimal(10, 2)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  pilot      Pilot      @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  model      DroneModel @relation(fields: [modelId], references: [id])
  missions   Mission[]
  flightLogs FlightLog[]

  @@index([pilotId])
  @@index([modelId])
  @@map("drones")
}

// ============================================================
// MISSIONS (3NF: purpose separated)
// ============================================================

model MissionPurpose {
  id     String @id @default(uuid()) @db.Uuid
  code   String @unique @db.VarChar(30)
  nameEs String @map("name_es") @db.VarChar(100)
  nameEn String @map("name_en") @db.VarChar(100)

  missions Mission[]

  @@map("mission_purposes")
}

model Mission {
  id                  String   @id @default(uuid()) @db.Uuid
  pilotId             String   @map("pilot_id") @db.Uuid
  droneId             String   @map("drone_id") @db.Uuid
  purposeId           String   @map("purpose_id") @db.Uuid
  name                String   @db.VarChar(200)
  purposeDetail       String?  @map("purpose_detail")
  plannedDate         DateTime @map("planned_date") @db.Date
  plannedLocationLat  Decimal  @map("planned_location_lat") @db.Decimal(10, 7)
  plannedLocationLng  Decimal  @map("planned_location_lng") @db.Decimal(10, 7)
  plannedLocationName String?  @map("planned_location_name") @db.VarChar(200)
  plannedAltitudeM    Decimal? @map("planned_altitude_m") @db.Decimal(6, 2)
  operationType       String   @map("operation_type") @db.VarChar(10) // VLOS, EVLOS, BVLOS
  status              String   @default("PLANNED") @db.VarChar(20)
  regulatoryVersion   String   @default("RAC100") @map("regulatory_version") @db.VarChar(20)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  pilot               Pilot                @relation(fields: [pilotId], references: [id])
  drone               Drone                @relation(fields: [droneId], references: [id])
  purpose             MissionPurpose       @relation(fields: [purposeId], references: [id])
  flightLogs          FlightLog[]
  checklistExecutions ChecklistExecution[]

  @@index([pilotId])
  @@index([droneId])
  @@map("missions")
}

// ============================================================
// FLIGHT LOGS & TELEMETRY
// ============================================================

model FlightLog {
  id                String    @id @default(uuid()) @db.Uuid
  missionId         String    @map("mission_id") @db.Uuid
  pilotId           String    @map("pilot_id") @db.Uuid
  droneId           String    @map("drone_id") @db.Uuid
  takeoffTime       DateTime  @map("takeoff_time") @db.Timestamptz
  landingTime       DateTime? @map("landing_time") @db.Timestamptz
  totalFlightMinutes Decimal? @map("total_flight_minutes") @db.Decimal(10, 2)
  takeoffLat        Decimal   @map("takeoff_lat") @db.Decimal(10, 7)
  takeoffLng        Decimal   @map("takeoff_lng") @db.Decimal(10, 7)
  takeoffAltitudeM  Decimal?  @map("takeoff_altitude_m") @db.Decimal(6, 2)
  landingLat        Decimal?  @map("landing_lat") @db.Decimal(10, 7)
  landingLng        Decimal?  @map("landing_lng") @db.Decimal(10, 7)
  maxAltitudeAglM   Decimal?  @map("max_altitude_agl_m") @db.Decimal(6, 2)
  maxDistanceM      Decimal?  @map("max_distance_m") @db.Decimal(8, 2)
  operationType     String    @map("operation_type") @db.VarChar(10)
  status            String    @default("IN_FLIGHT") @db.VarChar(20)
  notes             String?
  regulatoryVersion String    @default("RAC100") @map("regulatory_version") @db.VarChar(20)
  djiSyncId         String?   @map("dji_sync_id") @db.VarChar(100)
  source            String    @default("MANUAL") @db.VarChar(20)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  mission         Mission               @relation(fields: [missionId], references: [id])
  pilot           Pilot                 @relation(fields: [pilotId], references: [id])
  drone           Drone                 @relation(fields: [droneId], references: [id])
  weatherSnapshot FlightWeatherSnapshot?
  telemetryPoints TelemetryPoint[]
  emergencyEvents EmergencyEvent[]

  @@index([missionId])
  @@index([pilotId])
  @@index([droneId])
  @@map("flight_logs")
}

// 3NF: Weather separated from flight log (independent snapshot entity)
model FlightWeatherSnapshot {
  id                String   @id @default(uuid()) @db.Uuid
  flightLogId       String   @unique @map("flight_log_id") @db.Uuid
  temperatureC      Decimal? @map("temperature_c") @db.Decimal(5, 2)
  windSpeedKmh      Decimal? @map("wind_speed_kmh") @db.Decimal(5, 2)
  windGustKmh       Decimal? @map("wind_gust_kmh") @db.Decimal(5, 2)
  windDirectionDeg  Int?     @map("wind_direction_deg")
  humidityPercent   Int?     @map("humidity_percent")
  visibility        String?  @db.VarChar(10) // GOOD, MODERATE, POOR
  visibilityKm      Decimal? @map("visibility_km") @db.Decimal(5, 2)
  kIndex            Decimal? @map("k_index") @db.Decimal(5, 2)
  precipitation     Boolean  @default(false)
  thunderstorm      Boolean  @default(false)
  cloudCoverPercent Int?     @map("cloud_cover_percent")
  pressureHpa       Decimal? @map("pressure_hpa") @db.Decimal(6, 2)
  recordedAt        DateTime @default(now()) @map("recorded_at") @db.Timestamptz

  flightLog FlightLog @relation(fields: [flightLogId], references: [id], onDelete: Cascade)

  @@map("flight_weather_snapshots")
}

model TelemetryPoint {
  id                  String   @id @default(uuid()) @db.Uuid
  flightLogId         String   @map("flight_log_id") @db.Uuid
  timestamp           DateTime @db.Timestamptz
  latitude            Decimal  @db.Decimal(10, 7)
  longitude           Decimal  @db.Decimal(10, 7)
  altitudeAglM        Decimal? @map("altitude_agl_m") @db.Decimal(6, 2)
  speedMs             Decimal? @map("speed_ms") @db.Decimal(6, 2)
  headingDeg          Decimal? @map("heading_deg") @db.Decimal(5, 2)
  batteryPercent      Int?     @map("battery_percent")
  signalStrength      Int?     @map("signal_strength")
  distanceFromPilotM  Decimal? @map("distance_from_pilot_m") @db.Decimal(8, 2)
  satelliteCount      Int?     @map("satellite_count")

  flightLog FlightLog @relation(fields: [flightLogId], references: [id], onDelete: Cascade)

  @@index([flightLogId, timestamp])
  @@map("telemetry_points")
}

// ============================================================
// CHECKLISTS (3NF: categories separated)
// ============================================================

model ChecklistTemplate {
  id       String  @id @default(uuid()) @db.Uuid
  type     String  @db.VarChar(20) // PRE_ASSEMBLY, CONFIGURATION, PRE_TAKEOFF, POST_FLIGHT
  version  Int     @default(1)
  nameEs   String  @map("name_es") @db.VarChar(100)
  isActive Boolean @default(true) @map("is_active")

  items      ChecklistTemplateItem[]
  executions ChecklistExecution[]

  @@unique([type, version])
  @@map("checklist_templates")
}

model ChecklistItemCategory {
  id     String @id @default(uuid()) @db.Uuid
  code   String @unique @db.VarChar(30)
  nameEs String @map("name_es") @db.VarChar(50)

  items ChecklistTemplateItem[]

  @@map("checklist_item_categories")
}

model ChecklistTemplateItem {
  id            String  @id @default(uuid()) @db.Uuid
  templateId    String  @map("template_id") @db.Uuid
  categoryId    String? @map("category_id") @db.Uuid
  orderIndex    Int     @map("order_index")
  textEs        String  @map("text_es")
  isCritical    Boolean @default(false) @map("is_critical")
  requiresPhoto Boolean @default(false) @map("requires_photo")

  template       ChecklistTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category       ChecklistItemCategory?  @relation(fields: [categoryId], references: [id])
  executionItems ChecklistExecutionItem[]

  @@index([templateId])
  @@map("checklist_template_items")
}

model ChecklistExecution {
  id          String    @id @default(uuid()) @db.Uuid
  missionId   String    @map("mission_id") @db.Uuid
  templateId  String    @map("template_id") @db.Uuid
  pilotId     String    @map("pilot_id") @db.Uuid
  startedAt   DateTime  @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  status      String    @default("IN_PROGRESS") @db.VarChar(20)
  isPassed    Boolean?  @map("is_passed")

  mission  Mission                  @relation(fields: [missionId], references: [id])
  template ChecklistTemplate        @relation(fields: [templateId], references: [id])
  pilot    Pilot                    @relation(fields: [pilotId], references: [id])
  items    ChecklistExecutionItem[]

  @@index([missionId])
  @@index([pilotId])
  @@map("checklist_executions")
}

model ChecklistExecutionItem {
  id             String    @id @default(uuid()) @db.Uuid
  executionId    String    @map("execution_id") @db.Uuid
  templateItemId String    @map("template_item_id") @db.Uuid
  isChecked      Boolean   @default(false) @map("is_checked")
  checkedAt      DateTime? @map("checked_at") @db.Timestamptz
  note           String?
  photoUrl       String?   @map("photo_url") @db.VarChar(500)

  execution    ChecklistExecution    @relation(fields: [executionId], references: [id], onDelete: Cascade)
  templateItem ChecklistTemplateItem @relation(fields: [templateItemId], references: [id])

  @@index([executionId])
  @@map("checklist_execution_items")
}

// ============================================================
// EMERGENCY
// ============================================================

model EmergencyContact {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(100)
  role         String   @db.VarChar(20) // ATC, BOMBEROS, POLICIA, AMBULANCIA, AEROCIVIL
  phone        String   @db.VarChar(20)
  frequencyMhz Decimal? @map("frequency_mhz") @db.Decimal(6, 3)
  airportCode  String?  @map("airport_code") @db.VarChar(4)
  region       String?  @db.VarChar(50)
  isDefault    Boolean  @default(false) @map("is_default")

  emergencyEvents EmergencyEvent[]

  @@map("emergency_contacts")
}

model EmergencyEvent {
  id           String    @id @default(uuid()) @db.Uuid
  flightLogId  String?   @map("flight_log_id") @db.Uuid
  pilotId      String    @map("pilot_id") @db.Uuid
  type         String    @db.VarChar(30) // FLYAWAY, SIGNAL_LOSS, BATTERY_CRITICAL, INJURY, AIRSPACE_VIOLATION
  triggeredAt  DateTime  @map("triggered_at") @db.Timestamptz
  latitude     Decimal?  @db.Decimal(10, 7)
  longitude    Decimal?  @db.Decimal(10, 7)
  altitudeM    Decimal?  @map("altitude_m") @db.Decimal(6, 2)
  description  String?
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz
  atcContacted Boolean   @default(false) @map("atc_contacted")
  atcContactId String?   @map("atc_contact_id") @db.Uuid

  flightLog  FlightLog?             @relation(fields: [flightLogId], references: [id])
  pilot      Pilot                  @relation(fields: [pilotId], references: [id])
  atcContact EmergencyContact?      @relation(fields: [atcContactId], references: [id])
  actions    EmergencyEventAction[]

  @@index([pilotId])
  @@map("emergency_events")
}

// 3NF: Actions normalized from JSON array to proper table
model EmergencyEventAction {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  actionText  String   @map("action_text")
  performedAt DateTime @default(now()) @map("performed_at") @db.Timestamptz

  event EmergencyEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("emergency_event_actions")
}

// ============================================================
// AIRSPACE (3NF: zone types separated)
// ============================================================

model AirspaceZoneType {
  id             String @id @default(uuid()) @db.Uuid
  code           String @unique @db.VarChar(20) // AIRPORT, MILITARY, GOVERNMENT, PRISON, CRITICAL_INFRA, TFR
  nameEs         String @map("name_es") @db.VarChar(50)
  defaultRadiusM Int?   @map("default_radius_m")

  zones AirspaceZone[]

  @@map("airspace_zone_types")
}

model AirspaceZone {
  id              String    @id @default(uuid()) @db.Uuid
  typeId          String    @map("type_id") @db.Uuid
  name            String    @db.VarChar(200)
  icaoCode        String?   @map("icao_code") @db.VarChar(4)
  centerLat       Decimal   @map("center_lat") @db.Decimal(10, 7)
  centerLng       Decimal   @map("center_lng") @db.Decimal(10, 7)
  radiusM         Int       @map("radius_m")
  geometryGeojson String?   @map("geometry_geojson")
  maxAltitudeM    Decimal?  @map("max_altitude_m") @db.Decimal(6, 2)
  isPermanent     Boolean   @default(true) @map("is_permanent")
  validFrom       DateTime? @map("valid_from") @db.Timestamptz
  validUntil      DateTime? @map("valid_until") @db.Timestamptz
  source          String    @default("BUNDLED") @db.VarChar(20)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  type AirspaceZoneType @relation(fields: [typeId], references: [id])

  @@index([typeId])
  @@map("airspace_zones")
}
